<p style="color: green"><%= notice %></p>

<% content_for :title, "Books" %>

<h1 class="text-gray-900 sm:text-1xl md:text-3xl mb-2">Books</h1>

<div id="books">
  <% @books.each do |book| %>
  <div class="max-w-sm mx-auto bg-white rounded-lg shadow-sm border border-gray-200 p-4  my-3">
    <%= render book %>
    <button class="bg-green-500 hover:bg-green-700 text-white py-1 px-2 border border-green-700 rounded my-2">
      <%= link_to "Show this book", book %>
    </button>
  </div>  
  <% end %>
</div>

<button class="bg-blue-500 hover:bg-blue-700 text-white py-1 px-2 border border-blue-700 rounded my-2">
  <%= link_to "New book", new_book_path %>
</button>

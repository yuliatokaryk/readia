<p style="color: green"><%= notice %></p>

<div class="max-w-sm mx-auto bg-white rounded-lg shadow-sm border border-gray-200 p-4  my-3">
  <%= render @book %>

  <div class="my-5">
    <% if policy(@book).update? %>
      <button class="bg-green-500 hover:bg-green-700 text-white py-1 px-2 border border-green-700 rounded">
        <%= link_to "Edit this book", edit_book_path(@book) %>
      </button>
    <% end %>

    <button class="bg-transparent hover:bg-blue-500 text-blue-700 hover:text-white py-1 px-2 border border-blue-500 hover:border-transparent rounded">
      <%= link_to "Back to books", books_path %>
    </button>

    <% if policy(@book).destroy? %>
      <%= button_to "Destroy this book", @book, method: :delete, class: "bg-red-500 hover:bg-red-700 text-white py-1 px-2 border border-red-700 rounded mt-5"%>
    <% end %>
  </div>
</div>
